PORT=3000
NODE_ENV=development

# Relativity - AIKB project (knowledge_documents, knowledge_chunks, knowledge_ingestion_jobs)
AIKB_SUPABASE_URL=
AIKB_SUPABASE_SERVICE_KEY=

# Relativity_Global project (master clients table)
GLOBAL_SUPABASE_URL=
GLOBAL_SUPABASE_SERVICE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Full RAG answers / general chat completions (services/openaiService.js
# generateRagAnswer/generateChatCompletion). Optional — defaults to gpt-4.1.
OPENAI_CHAT_MODEL=
# Cheaper/faster model for the intent classifier and retrieval query
# rewriter (services/openaiService.js). Optional — defaults to gpt-4o-mini.
OPENAI_LIGHTWEIGHT_MODEL=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Optional — retry count applied to every Inngest function in
# inngest/functions.js. Defaults to 3 if unset.
INNGEST_DEFAULT_RETRIES=

# Supabase Storage — required for portal_upload source provider
# The bucket must exist in the AIKB Supabase project
AIKB_STORAGE_BUCKET=aikb-documents

# Max file size for ingestion (bytes). Default: 10 MB
MAX_UPLOAD_BYTES=10485760

# Google Drive sync has been intentionally removed.
# These variables are no longer used by this backend.
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Optional — page size for the (currently unreferenced) googleDriveService.js
# file listing. Defaults to 200 if unset.
GOOGLE_DRIVE_PAGE_SIZE=

# API security — used by Relativity portal and internal scripts
API_KEY=

# Optional — defense-in-depth rate limit across all of /api/knowledge
# (middleware/rateLimit.js). Defaults to a 15-minute window with a cap of
# 2000 requests if unset.
KNOWLEDGE_API_RATE_LIMIT_WINDOW_MS=
KNOWLEDGE_API_RATE_LIMIT_MAX=

# Optional — result-set caps for admin/analytics-style reads
# (services/supabaseService.js). Defaults shown are each function's
# pre-existing behavior; only set these to tune dashboard completeness vs.
# query cost as per-client data volume grows.
# Default: 100 — fetchRecentIngestionJobs' window for client stats/health endpoints.
RECENT_INGESTION_JOBS_LIMIT=
# Default: 10 — "recent" slice shown in analytics/stats responses (gaps, failed jobs, ingestion activity).
RECENT_ACTIVITY_LIMIT=
# Default: 8 — prior messages fed to the intent classifier/retrieval query rewriter as conversation context.
CHAT_CONTEXT_MESSAGE_LIMIT=
# Default: 200 — row cap for the admin knowledge-gaps list.
KNOWLEDGE_GAPS_LIST_LIMIT=

# Slack — legacy MVP RAG bot interface (routes/slack.js)
# DEPRECATED: POST /api/slack/events now returns 410 for every event_callback
# and no longer posts to Slack (Architecture Review Phase 4, Milestone 1 —
# chore/disable-legacy-slack). SLACK_BOT_TOKEN was removed from config/index.js
# (backlog L7) — the code no longer reads it at all, so it's safe to remove
# from production too.
# Still required in production: signature verification on /api/slack/events
# remains active even though the endpoint is retired.
SLACK_SIGNING_SECRET=

# Architecture Review Phase 4, Milestone 4 (§4.10) — HMAC-signed envelope
# shared with Relativity, scoped only to POST /api/knowledge/ask (verified
# here) and POST /api/integrations/slack/deliver (signed here, verified by
# Relativity). Must match Relativity's SERVICE_REQUEST_SIGNING_SECRET exactly.
SERVICE_REQUEST_SIGNING_SECRET=

# Relativity's base URL, used only to call back POST
# /api/integrations/slack/deliver once a Slack-originated question has an
# answer (services/relativityDeliverClient.js). AIKB never calls any other
# Relativity route.
RELATIVITY_API_BASE_URL=
RELATIVITY_DELIVER_TIMEOUT_MS=8000
