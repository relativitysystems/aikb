PORT=3000
NODE_ENV=development

# Relativity - AIKB project (knowledge_documents, knowledge_chunks, knowledge_ingestion_jobs)
AIKB_SUPABASE_URL=
AIKB_SUPABASE_SERVICE_KEY=

# Relativity_Global project (master clients table)
GLOBAL_SUPABASE_URL=
GLOBAL_SUPABASE_SERVICE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Supabase Storage — required for portal_upload source provider
# The bucket must exist in the AIKB Supabase project
AIKB_STORAGE_BUCKET=aikb-documents

# Max file size for ingestion (bytes). Default: 10 MB
MAX_UPLOAD_BYTES=10485760

# Google Drive sync has been intentionally removed.
# These variables are no longer used by this backend.
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# API security — used by Relativity portal and internal scripts
API_KEY=

# Slack — legacy MVP RAG bot interface (routes/slack.js)
# DEPRECATED: POST /api/slack/events now returns 410 for every event_callback
# and no longer reads this token or posts to Slack (Architecture Review
# Phase 4, Milestone 1 — chore/disable-legacy-slack). Safe to remove from
# production once the route file itself is deleted; not removed here.
SLACK_BOT_TOKEN=
# Still required in production: signature verification on /api/slack/events
# remains active even though the endpoint is retired.
SLACK_SIGNING_SECRET=

# Architecture Review Phase 4, Milestone 4 (§4.10) — HMAC-signed envelope
# shared with Relativity, scoped only to POST /api/knowledge/ask (verified
# here) and POST /api/integrations/slack/deliver (signed here, verified by
# Relativity). Must match Relativity's SERVICE_REQUEST_SIGNING_SECRET exactly.
SERVICE_REQUEST_SIGNING_SECRET=

# Relativity's base URL, used only to call back POST
# /api/integrations/slack/deliver once a Slack-originated question has an
# answer (services/relativityDeliverClient.js). AIKB never calls any other
# Relativity route.
RELATIVITY_API_BASE_URL=
RELATIVITY_DELIVER_TIMEOUT_MS=8000
